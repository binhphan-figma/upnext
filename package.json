{
  "name": "upnext",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @upnext/web --filter @upnext/api dev",
    "build": "pnpm prepare:generated && pnpm -r build",
    "lint": "pnpm prepare:generated && eslint . --max-warnings=0",
    "typecheck": "pnpm prepare:generated && pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare:generated": "pnpm --filter @upnext/database generate && pnpm --filter @upnext/domain build",
    "db:generate": "pnpm --filter @upnext/database generate",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/upnext?schema=public} pnpm --filter @upnext/database validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@next/eslint-plugin-next": "^15.3.2",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  }
}
